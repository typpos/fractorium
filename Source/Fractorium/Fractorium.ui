              <number>2</number>
             </property>
             <attribute name="horizontalHeaderVisible">
              <bool>false</bool>
             </attribute>
             <attribute name="horizontalHeaderMinimumSectionSize">
              <number>35</number>
             </attribute>
             <attribute name="horizontalHeaderDefaultSectionSize">
