$subspace=g 0
g=$companion([1,1,-2])
&Q=$semigroup([-1])*$vector(0)
h0=Q
h1=Q
h2=Q
h3=Q
A0=g^-1*h0*A0|g^-2*h1*A0|g^-2*h2*A0|g^-3*h3*A0

