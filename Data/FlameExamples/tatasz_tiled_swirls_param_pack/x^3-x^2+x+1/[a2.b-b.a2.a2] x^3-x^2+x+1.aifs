$n=1.093364_21
h0=-1*[0,1,0]
h1=-1*[1,0,0]
h2=-1*[0,0,0]
h3=1*[0,0,0]
h4=-1*[0,0,0]

@:G
$n=1.093364_44
h0=-1*[0,-1,0]
h1=1*[0,1,0]
h2=1*[0,1,0]
h3=-1*[0,-1,0]
h4=1*[0,1,0]

@:G
$n=1.093364_53
h0=-1*[0,0,-1]
h1=1*[0,1,0]
