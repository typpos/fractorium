@@version 3

@G
$n=[b0.a-a.a3.a2]B2[x^3-x^2+2x+1]
$dim=3
$subspace=g 0
g=$companion([1,2,-1])
&Q=$semigroup([-1])*$vector(0)
h0=Q
h1=Q
h2=Q
h3=Q
h4=Q
A0=h0*A1|g^-1*h1*A0
A1=g^-1*h2*A0|g^-3*h3*A0|g^-2*h4*A0

@:G
$n=1.348255_32
h0=1*[1,0,0]
h1=-1*[0,0,0]
h2=-1*[0,0,0]
h3=-1*[0,0,-1]
h4=1*[1,1,0]

@:G
$n=1.152204_25
h0=-1*[1,-1,1]
h1=1*[0,1,0]
h2=1*[0,0,0]
h3=-1*[0,1,-1]
h4=1*[-1,0,1]


